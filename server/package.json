{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "eval:synthetic": "node evaluation/run-synthetic-eval.mjs",
    "eval:real": "node evaluation/run-real-eval.mjs",
    "eval:trajectory": "node evaluation/run-trajectory-eval.mjs",
    "eval:planner": "node evaluation/run-planner-eval.mjs",
    "eval:param-sweep": "node evaluation/run-param-sweep.mjs",
    "eval:rerank": "node evaluation/run-rerank-eval.mjs",
    "eval:rerank:sweep": "node evaluation/run-rerank-sweep.mjs",
    "corpus:arxiv": "node evaluation/build-arxiv-corpus.mjs",
    "rerank:cross-encoder:setup": "python3 -m venv --clear --system-site-packages evaluation/.venv-neural-reranker && PYTHONNOUSERSITE=1 evaluation/.venv-neural-reranker/bin/python -m pip install -r evaluation/neural-reranker-requirements.txt",
    "rerank:cross-encoder": "PYTHONNOUSERSITE=1 USE_TF=0 USE_FLAX=0 TRANSFORMERS_NO_TF=1 TRANSFORMERS_NO_FLAX=1 HF_HOME=evaluation/generated/huggingface evaluation/.venv-neural-reranker/bin/python evaluation/neural-cross-encoder-endpoint.py",
    "rerank:cross-encoder:docker": "docker compose -f evaluation/cross-encoder-service/compose.yaml up --build",
    "rerank:cross-encoder:local": "node evaluation/local-cross-encoder-endpoint.mjs",
    "feedback:corpus": "node evaluation/build-feedback-corpus.mjs",
    "eval:feedback": "node evaluation/build-feedback-corpus.mjs && node evaluation/run-synthetic-eval.mjs evaluation/generated/feedback-corpus.json --latest-name latest-feedback",
    "eval:recovery-observability": "node evaluation/run-recovery-observability-eval.mjs",
    "eval:ragas": "python evaluation/run-ragas-eval.py",
    "bench:rerank": "node evaluation/benchmark-rerank-latency.mjs",
    "observability:report": "node evaluation/build-observability-report.mjs",
    "planner:gate": "node evaluation/check-planner-provider-gate.mjs",
    "quality:gate": "node evaluation/check-quality-gate.mjs",
    "coverage:gate": "node test/coverage-gate.mjs",
    "coverage:targets": "node test/coverage-gate.mjs --strict-targets",
    "test": "node test/run.test.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@langchain/classic": "^1.0.5",
    "@langchain/community": "^1.0.5",
    "@langchain/core": "^1.1.0",
    "@langchain/openai": "^1.1.3",
    "@modelcontextprotocol/sdk": "^1.23.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "fast-xml-parser": "^5.8.0",
    "langchain": "^1.1.1",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.20.0",
    "serpapi": "^2.2.1",
    "zod": "^4.1.13"
  },
  "type": "module"
}
