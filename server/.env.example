OPENAI_API_KEY=your_openai_api_key
SERPAPI_KEY=your_serpapi_key
VECTOR_STORE_PROVIDER=local
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=rag_chunks
QDRANT_DISTANCE=Cosine
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-5
AGENT_PLANNER_ROLLOUT=llm
AGENT_INTENT_PLANNER=llm
AGENT_EXECUTION_PLANNER=llm
RAG_PROMPT_VERSION=v2
RAG_CHUNK_STRATEGY=structured
RAG_HYBRID_ENABLED=false
RAG_HYBRID_FUSION=weighted
RAG_HYBRID_DENSE_WEIGHT=0.65
RAG_HYBRID_SPARSE_WEIGHT=0.35
RAG_RRF_K=60
RAG_QUERY_DECOMPOSITION_ENABLED=true
RAG_QUERY_DECOMPOSITION_MAX_REQUIREMENTS=4
RAG_RERANK_ENABLED=false
RAG_RERANK_PROVIDER=heuristic
RAG_RERANK_CANDIDATE_MULTIPLIER=3
RAG_RERANK_WEIGHT=0.6
RAG_CROSS_ENCODER_ENDPOINT=
RAG_CROSS_ENCODER_MODEL=
# Defaults to enabled when POSTGRES_DATABASE_URL or LONG_MEMORY_DATABASE_URL is configured.
# Set these to false to force memory off even when PostgreSQL is configured.
# RAG_LONG_MEMORY_ENABLED=false
# RAG_AGENT_EXPERIENCE_MEMORY_ENABLED=false
RAG_OBSERVABILITY_ENABLED=false
RAG_OBSERVABILITY_INCLUDE_CONTEXT=false
POSTGRES_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/agentai
POSTGRES_SSL_ENABLED=false
LONG_MEMORY_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/agentai
LONG_MEMORY_POSTGRES_TABLE=long_memory_items
LONG_MEMORY_POSTGRES_SSL_ENABLED=false
DOCUMENTS_POSTGRES_TABLE=rag_documents
SESSION_MEMORY_POSTGRES_TABLE=rag_session_memory
TASK_STORE_PROVIDER=auto
TASKS_POSTGRES_TABLE=rag_tasks
TASK_EVENTS_POSTGRES_TABLE=rag_task_events
AGENT_RUN_STORE_PROVIDER=auto
AGENT_RUN_RECOVERY_MODE=
AGENT_RUNS_POSTGRES_TABLE=rag_agent_runs
AGENT_RUN_EVENTS_POSTGRES_TABLE=rag_agent_run_events
ADMIN_AUDIT_STORE_PROVIDER=auto
ADMIN_AUDIT_EVENTS_POSTGRES_TABLE=rag_admin_audit_events
ADMIN_AUDIT_RETENTION_DAYS=90
API_AUTH_ENABLED=false
API_AUTH_TOKEN=change-me-for-local-dev
# API_AUTH_TOKENS can include admin roles/permissions, for example:
# {"admin-token":{"userId":"admin","workspaceId":"workspace-a","roles":["admin.operator"]}}
API_AUTH_TOKENS=
API_AUTH_REQUIRE_WORKSPACE=false
API_AUTH_JWT_ENABLED=false
API_AUTH_JWT_HS256_SECRET=
API_AUTH_JWT_SECRET=
API_AUTH_JWT_ISSUER=
API_AUTH_JWT_AUDIENCE=
API_AUTH_JWT_USER_CLAIM=sub
API_AUTH_JWT_WORKSPACE_CLAIM=workspace_id
API_AUTH_JWT_WORKSPACES_CLAIM=workspaces
API_AUTH_JWT_ROLES_CLAIM=roles
API_AUTH_JWT_PERMISSIONS_CLAIM=permissions
API_AUTH_REVOKED_TOKEN_HASHES=
API_AUTH_REVOKED_JTIS=
FEEDBACK_DIRECTORY=
STARTUP_HEALTH_STRICT=false
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=180
RAG_RETRIEVAL_TOP_K=6
RAG_SPARSE_TOP_K=8
RAG_COMPARE_TOP_K_PER_DOC=3
RAG_MIN_QUERY_TERM_COVERAGE=0.51
